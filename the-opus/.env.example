# ── Copy this file to .env.local and fill in real values. NEVER commit .env.local ──

# Supabase (from your NEW hackathon project → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Used for admin actions (creating users). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini (from Google AI Studio → API Keys). Used for embeddings + AI features.
GEMINI_API_KEY=your-gemini-api-key
