# ── This is a TEMPLATE that IS committed to git. Put NO real secrets here. ──
# ── Copy to .env.local (gitignored) and fill in real values there. ──

# Supabase (from your hackathon project → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Used for admin actions (creating users). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (the key the organizers gave us). Powers BOTH:
#  - semantic-search embeddings (openai/text-embedding-3-small, 768-dim)
#  - text generation for Run + AI features
OPENROUTER_API_KEY=your-openrouter-key
# Optional model overrides (two tiers, chosen per use case):
#  QUALITY (user-facing, e.g. Run): default anthropic/claude-sonnet-4.6
#    (max: anthropic/claude-opus-4.8 · alt: openai/gpt-5.5)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
#  FAST (utility: auto-metadata, eval scoring): default google/gemini-3.5-flash
# OPENROUTER_FAST_MODEL=google/gemini-3.5-flash
