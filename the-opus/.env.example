# ── Copy this file to .env.local and fill in real values. NEVER commit .env.local ──

# Supabase (from your NEW hackathon project → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Used for admin actions (creating users). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (the key the organizers gave us). Powers BOTH:
#  - semantic-search embeddings (openai/text-embedding-3-small, 1536-dim)
#  - text generation for AI features
OPENROUTER_API_KEY=your-openrouter-key
# Optional: override the generation model (default openai/gpt-4o-mini)
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
